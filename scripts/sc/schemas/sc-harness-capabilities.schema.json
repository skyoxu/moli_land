{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sc-harness-capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_version",
    "cmd",
    "task_id",
    "run_id",
    "delivery_profile",
    "security_profile",
    "supported_sidecars",
    "supported_recovery_actions",
    "approval_contract_supported"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1
    },
    "cmd": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "delivery_profile": {
      "type": "string",
      "minLength": 1
    },
    "security_profile": {
      "type": "string",
      "minLength": 1
    },
    "supported_sidecars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supported_recovery_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval_contract_supported": {
      "type": "boolean"
    }
  }
}
