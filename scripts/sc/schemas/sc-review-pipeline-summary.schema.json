{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newrouge.local/schemas/sc-review-pipeline-summary.schema.json",
  "title": "sc-review-pipeline summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cmd",
    "task_id",
    "requested_run_id",
    "run_id",
    "allow_overwrite",
    "force_new_run_id",
    "status",
    "steps"
  ],
  "properties": {
    "cmd": {
      "const": "sc-review-pipeline"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "requested_run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$"
    },
    "allow_overwrite": {
      "type": "boolean"
    },
    "force_new_run_id": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "fail"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "cmd",
        "rc",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "sc-test",
            "sc-acceptance-check",
            "sc-llm-review"
          ]
        },
        "cmd": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rc": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "fail",
            "skipped",
            "planned"
          ]
        },
        "log": {
          "type": "string"
        },
        "reported_out_dir": {
          "type": "string"
        },
        "summary_file": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "ok",
                  "fail"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "log"
            ]
          }
        }
      ]
    }
  }
}
