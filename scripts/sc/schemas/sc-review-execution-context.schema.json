{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godotgame.local/schemas/sc-review-execution-context.schema.json",
  "title": "sc-review execution-context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "status",
    "failed_step"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "cmd": {
      "const": "sc-review-pipeline"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "requested_run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "fail"
      ]
    },
    "delivery_profile": {
      "type": "string",
      "minLength": 1
    },
    "security_profile": {
      "type": "string",
      "enum": [
        "strict",
        "host-safe"
      ]
    },
    "failed_step": {
      "type": "string"
    },
    "paths": {
      "type": "object"
    },
    "git": {
      "type": "object"
    },
    "recovery": {
      "type": "object"
    },
    "marathon": {
      "type": "object"
    },
    "agent_review": {
      "type": "object"
    },
    "llm_review": {
      "type": "object"
    },
    "approval": {
      "$ref": "#/$defs/approval"
    }
  },
  "$defs": {
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "soft_gate": {
          "type": "boolean"
        },
        "required_action": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "request_path": {
          "type": "string"
        },
        "response_path": {
          "type": "string"
        }
      }
    }
  }
}
