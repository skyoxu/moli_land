{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sc-approval-request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "task_id",
    "run_id",
    "action",
    "reason",
    "requested_files",
    "requested_commands",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "requested_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending"
      ]
    }
  }
}
