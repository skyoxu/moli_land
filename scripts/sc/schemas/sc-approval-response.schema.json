{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sc-approval-response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "decision",
    "reviewer",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "denied"
      ]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
