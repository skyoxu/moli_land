* text=auto eol=lf

# Text files (repository-stable LF by default)
*.md      text eol=lf
*.txt     text eol=lf
*.cs      text diff=csharp eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.gd      text eol=lf
*.tscn    text eol=lf
*.tres    text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.ps1     text eol=lf
*.py      text eol=lf
*.editorconfig text eol=lf

# Windows command wrappers
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files (no EOL conversions)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.ico  binary
*.ogg  binary
*.wav  binary
*.mp3  binary
*.zip  binary
*.7z   binary
*.exe  binary
*.dll  binary
*.pdb  binary
*.pck  binary
